{
  "name": "@z-notes/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "hash": "tsx scripts/hash.ts",
    "restore": "tsx scripts/restore.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.4",
    "@z-notes/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "jszip": "^3.10.1",
    "node-cron": "^3.0.3",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.1",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}

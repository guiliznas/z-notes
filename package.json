{
  "name": "z-notes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:shared": "pnpm --filter @z-notes/shared build",
    "dev": "pnpm build:shared && pnpm -r --parallel --filter \"./apps/*\" dev",
    "build": "pnpm build:shared && pnpm --filter @z-notes/web build && pnpm --filter @z-notes/server build",
    "start": "pnpm --filter @z-notes/server start",
    "test": "pnpm build:shared && pnpm -r test",
    "typecheck": "pnpm build:shared && pnpm -r typecheck"
  }
}

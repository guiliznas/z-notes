# Porta do servidor
PORT=8787

# Senha de acesso (single user). Em dev, informe a senha em texto:
Z_NOTES_PASSWORD=changeme

# Em produção, prefira informar o hash bcrypt (gere com: pnpm --filter @z-notes/server hash "sua-senha")
# Z_NOTES_PASSWORD_HASH=

# Segredo para assinar o cookie de sessão (troque em produção)
Z_NOTES_SESSION_SECRET=troque-este-segredo

# Segredo para assinar tokens JWT (Bearer auth para mobile/desktop). Troque em produção.
# Z_NOTES_JWT_SECRET=troque-este-outro-segredo

# Diretório de dados (SQLite + espelho .md). Default: ./data
# Z_NOTES_DATA_DIR=/caminho/absoluto/para/data

# --- Backup automático ---
# Diretório dos snapshots (separado do data/ ativo). Default: ./backups
# Z_NOTES_BACKUP_DIR=/caminho/absoluto/para/backups

# Expressão cron do agendamento diário. Default: 3h da manhã.
# Z_NOTES_BACKUP_CRON=0 3 * * *

# URL opcional para notificação (POST) caso o backup falhe (ex: ntfy.sh, webhook do Discord/Slack).
# Z_NOTES_BACKUP_WEBHOOK_URL=

# Porta do servidor
PORT=8787

# Senha de acesso (single user). Em dev, informe a senha em texto:
Z_NOTES_PASSWORD=changeme

# Em produção, prefira informar o hash bcrypt (gere com: pnpm --filter @z-notes/server hash "sua-senha")
# Z_NOTES_PASSWORD_HASH=

# Segredo para assinar o cookie de sessão (troque em produção)
Z_NOTES_SESSION_SECRET=troque-este-segredo

# Diretório de dados (SQLite + espelho .md). Default: ./data
# Z_NOTES_DATA_DIR=/caminho/absoluto/para/data
